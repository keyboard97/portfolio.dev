---
interface Props {
  title: string;
  description: string;
  lang?: string;
  page?: string;
  canonical?: string;
}

const { title, description, lang = "en", page = "home", canonical } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://adrianrdguez.dev";
const origin = Astro.url.origin;
const ogImageUrl = `${origin}/og/${lang}/${page}.png`;
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
---

<!-- Primary -->
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content="index, follow" />
<meta name="author" content="Adrián Rodríguez" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content="Adrián Rodríguez" />
<meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- JSON-LD -->
<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Adrián Rodríguez",
  "url": siteUrl,
  "jobTitle": "Software Engineer · Fullstack Developer",
  "sameAs": [
    "https://github.com/keyboard97",
    "https://www.linkedin.com/in/arodriguez797/"
  ]
})} />
