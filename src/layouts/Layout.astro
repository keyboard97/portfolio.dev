---
import { ViewTransitions } from "astro:transitions";
import ChangeLanguage from "../components/ChangeLanguage";
import FollowMouseEffect from "../components/FollowMouseEffect.astro";
import SEO from "../components/SEO.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  page?: string;
}

const {
  title,
  description = "Software Engineer and Fullstack Developer building elegant web applications. Explore my projects, experience, and skills.",
  page = "home",
} = Astro.props;

const lang = Astro.currentLocale ?? "en";
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <SEO title={title} description={description} lang={lang} page={page} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />

    <script>
      import posthog from "posthog-js";
      posthog.init(import.meta.env.PUBLIC_POSTHOG_API_KEY!, {
        api_host: import.meta.env.PUBLIC_POSTHOG_API_HOST,
      });
    </script>
  </head>
  <body class="min-h-screen h-full w-full max-w-[1920px] mx-auto">
    <header class="fixed top-2 right-4 z-50">
      <ChangeLanguage client:only="react" />
    </header>
    <main class="h-full w-full">
      <slot />
    </main>
    <footer class="w-full mt-8 py-8 relative rounded-t-lg bg-hover-bg-color backdrop-blur-md" >
      <div class="max-w-4xl mx-auto px-6 flex items-center justify-center gap-12 flex-wrap">
        <img
          src="/logo_xunta.png"
          alt="Xunta de Galicia"
          class="h-10 object-contain"
          style="filter: brightness(0) invert(1) opacity(0.85);"
        />
        <img
          src="/xacobeo-2027_logo.png"
          alt="Xacobeo 2027"
          class="h-10 object-contain opacity-85"
        />
        <img
          src="/logo_eu.png"
          alt="Cofinanciado pola Unión Europea"
          class="h-10 object-contain"
          style="filter: brightness(1.1) saturate(1.1) opacity(0.9);"
        />
        <img
          src="/logo_fondos.png"
          alt="Fondos Europeos"
          class="h-10 object-contain"
          style="filter: brightness(0) invert(1) opacity(0.85);"
        />
      </div>
    </footer>
    <FollowMouseEffect />
  </body>
</html>
