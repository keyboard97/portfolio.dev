---
import ProjectCard from "../components/ProjectCard.astro";
import { useTranslations, type LocaleType } from "../i18n";
import Layout from "../layouts/Layout.astro";
import type { Project } from "../types/Project";

const t = useTranslations(Astro.currentLocale as LocaleType);
const projects = (t("info.projects") as Project[]).filter((x) => x.active);
---

<Layout
  title="Projects — Adrián Rodríguez"
  description="Explore web applications, tools, and experiments built by Adrián Rodríguez — Fullstack Developer."
  page="projects"
>
  <div class="flex flex-col gap-4 w-[90%] md:w-[80%] lg:w-[60%] 2xl:w-[50%] mx-auto my-24">
    <h1 class="text-4xl font-bold">{t("projects")}</h1>
    {projects.map((pro) => <ProjectCard {...pro} imageFull />)}
  </div>
</Layout>
